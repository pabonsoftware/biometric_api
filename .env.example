# =========================================================
# Biometric API - Variables de entorno (ejemplo)
# Copiar a .env y ajustar valores
# =========================================================

# --- Django ---
DJANGO_SETTINGS_MODULE=config.settings.dev
DJANGO_SECRET_KEY=change-me-in-production
DJANGO_DEBUG=True
DJANGO_ALLOWED_HOSTS=localhost,127.0.0.1,0.0.0.0

# --- Base de datos PostgreSQL ---
POSTGRES_DB=biometric_db
POSTGRES_USER=biometric_user
POSTGRES_PASSWORD=biometric_pass
POSTGRES_HOST=db
POSTGRES_PORT=5432

# --- Redis (broker de Celery) ---
REDIS_URL=redis://redis:6379/0
CELERY_BROKER_URL=redis://redis:6379/0
CELERY_RESULT_BACKEND=redis://redis:6379/1
# En dev se puede dejar en True para ejecutar tareas síncronas sin worker
CELERY_TASK_ALWAYS_EAGER=False

# --- AWS S3 (para PDFs y QRs) ---
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_STORAGE_BUCKET_NAME=biometric-api-bucket
AWS_S3_REGION_NAME=us-east-1
AWS_S3_CUSTOM_DOMAIN=
# Si está vacío, los archivos no se sirven públicamente y se firman URLs
AWS_QUERYSTRING_AUTH=True

# --- Frontend (para los enlaces del QR) ---
FRONTEND_BASE_URL=http://localhost:3000

# --- Email (SMTP) ---
# Opción A — En dev: console backend (los correos se imprimen en stdout)
#EMAIL_BACKEND=django.core.mail.backends.console.EmailBackend
#EMAIL_HOST=smtp.gmail.com
#EMAIL_PORT=587
#EMAIL_USE_TLS=True
#EMAIL_HOST_USER=
#EMAIL_HOST_PASSWORD=
# Opción B — Mailpit (UI web en http://localhost:8025/)
EMAIL_BACKEND=django.core.mail.backends.smtp.EmailBackend
EMAIL_HOST=mailpit
EMAIL_PORT=1025
EMAIL_USE_TLS=False
EMAIL_HOST_USER=
EMAIL_HOST_PASSWORD=
DEFAULT_FROM_EMAIL=Biometric API <noreply@biometric.local>
# Destinatarios fijos para notificaciones de programación de mantenimientos (CSV)
MAINTENANCE_NOTIFICATION_EMAILS=mantenimiento@clinic.test,jefe@clinic.test

# --- CORS ---
CORS_ALLOWED_ORIGINS=http://localhost:3000,http://127.0.0.1:3000

# --- JWT ---
JWT_ACCESS_TOKEN_LIFETIME_MINUTES=60
JWT_REFRESH_TOKEN_LIFETIME_DAYS=7
